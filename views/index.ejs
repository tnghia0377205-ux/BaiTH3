<%- include('layouts/header') %>

<nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top">
  <div class="container">
    <a class="navbar-brand" href="/">My Website</a>
    <div>
      <a class="nav-link d-inline" href="/">Home</a>
      <a class="nav-link d-inline" href="/list">Danh sách</a>
      <a class="nav-link d-inline" href="/contact">Liên hệ</a>
    </div>
  </div>
</nav>

<header class="masthead text-white text-center">
  <div class="container">
    <h1>Website du lịch 🚀</h1>
    <a href="/list" class="btn btn-primary">Xem danh sách</a>
  </div>
</header>

<div class="container mt-5">
  <div class="row">

    <% if(items.length === 0){ %>
      <p class="text-center">Không có dữ liệu</p>
    <% } else { %>
      <% items.forEach(item => { %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <img src="/assets/img/portfolio/thumbnails/1.jpg" class="card-img-top">
            <div class="card-body">
              <h5><%= item.name %></h5>
              <p><%= item.description %></p>
              <p>Giá: <%= item.price.toLocaleString() %> VNĐ</p>
              <% if(item.hot){ %>
                <span class="badge bg-danger">Hot</span>
              <% } else { %>
                <span class="badge bg-secondary">Normal</span>
              <% } %>
              <br><br>
              <a href="/detail/<%= item.id %>" class="btn btn-success">Chi tiết</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>

  </div>
</div>

<%- include('layouts/footer') %>